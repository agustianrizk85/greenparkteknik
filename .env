# ----------------------------------------------------------------------------
# Konfigurasi frontend Teknik. Variabel berawalan VITE_ dibaca oleh Vite.
# ----------------------------------------------------------------------------

# Port server dev & preview frontend.
# Kosongkan (VITE_PORT=) untuk port DINAMIS — OS memilih port bebas otomatis.
VITE_PORT=5174

# Base URL backend API (Go). Sesuaikan host/port bila backend berbeda.
VITE_API_BASE=http://localhost:8083
